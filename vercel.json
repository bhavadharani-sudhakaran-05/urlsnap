{
  "rewrites": [
    {
      "source": "/(login|register|dashboard|settings|qr-generator|expired)",
      "destination": "/index.html"
    },
    {
      "source": "/analytics/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/([a-zA-Z0-9_-]{3,32})",
      "destination": "https://urlsnap-pydi.onrender.com/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "https://urlsnap-pydi.onrender.com/api"
  }
}
